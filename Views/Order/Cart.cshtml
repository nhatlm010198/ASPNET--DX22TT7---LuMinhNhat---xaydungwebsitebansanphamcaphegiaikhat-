@model List<CoffeeShopWebsite.Models.OrderDetail>

<h2>Giỏ hàng</h2>

<table class="table">
    <tr>
        <th>Sản phẩm</th>
        <th>Số lượng</th>
        <th>Đơn giá</th>
        <th>Thành tiền</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Product.ProductName</td>
            <td>@item.Quantity</td>
            <td>@item.UnitPrice.ToString("N0")</td>
            <td>@(item.Quantity * item.UnitPrice).ToString("N0")</td>
        </tr>
    }
</table>

<a href="@Url.Action("Checkout", "Order")" class="btn btn-primary">Thanh toán</a>
